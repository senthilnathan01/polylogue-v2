# Required: Gemini API key used for topic extraction, synthesis, critique, and report writing.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Required: Supadata API key used as the single transcript provider.
SUPADATA_API_KEY="YOUR_SUPADATA_API_KEY"

# Required: YouTube Data API v3 key used to search for supporting videos and fetch metadata.
YOUTUBE_DATA_API_KEY="YOUR_YOUTUBE_DATA_API_KEY"

# Optional: reuse a cached report for this many hours.
REPORT_CACHE_HOURS="24"

# Optional: limit new report generations per day. Set 0 or a negative number to disable.
DAILY_REPORT_LIMIT="25"

# Optional: send a webhook when usage crosses ALERT_THRESHOLD_PERCENT.
ALERT_THRESHOLD_PERCENT="60"
ALERT_WEBHOOK_URL="https://example.com/webhook"

# Recommended for Agent Packet 2 durable persistence. Without these, the app falls back to the local repository adapter.
SUPABASE_URL="YOUR_SUPABASE_URL"
SUPABASE_SERVICE_KEY="YOUR_SUPABASE_SERVICE_KEY"
SUPABASE_ARTIFACTS_BUCKET="research-artifacts"
SUPABASE_INLINE_ARTIFACT_MAX_BYTES="20000"
